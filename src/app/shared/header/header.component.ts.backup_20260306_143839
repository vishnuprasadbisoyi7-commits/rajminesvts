export class HeaderComponent implements OnInit, OnDestroy {
  breadcrumbText = 'Dashboard';
  userName = 'User';
  userCategory = '';
  currentLanguage: Language = 'en';
  private languageSubscription?: Subscription;

  constructor(
    private router: Router,
    private translationService: TranslationService,
    private authService: AuthService
  ) {
    this.router.events
      .pipe(filter(event => event instanceof NavigationEnd))
      .subscribe((event: any) => {
        this.updateBreadcrumb(event.url);
        this.updateUserInfo();
      });
    
    // Initialize user info
    this.updateUserInfo();
  }

  ngOnInit(): void {
    this.currentLanguage = this.translationService.getCurrentLanguage();
    // Subscribe to language changes to update breadcrumb
    this.languageSubscription = this.translationService.language$.subscribe(() => {
      this.updateBreadcrumb(this.router.url);
    });
  }

  ngOnDestroy(): void {
    this.languageSubscription?.unsubscribe();
  }

  translate(key: string): string {
    return this.translationService.translate(key);
  }

  onLanguageChange(): void {
    this.translationService.setLanguage(this.currentLanguage);
  }
  logout(): void {
    sessionStorage.clear();
    this.authService.logout();
  }

  private updateUserInfo(): void {
    try {
      const userStr = sessionStorage.getItem('user');
      const role = sessionStorage.getItem('role') || 'system-admin';
      
      if (userStr) {
        const user = JSON.parse(userStr);
        
        // Get role-specific user name
        const roleUserMap: { [key: string]: { name: string; category: string } } = {
          'system-admin': { name: user.systemAdminName || 'VTS Admin', category: 'VTS Administrator' },
          'gps-vendor': { name: user.gpsVendorName || 'Vendor Manager', category: 'GPS Vendor' },
          'occ': { name: user.name || 'OCC User', category: 'OCC' }
        };
        
        const roleInfo = roleUserMap[role] || { name: user.name || 'User', category: '' };
        this.userName = roleInfo.name;
        this.userCategory = roleInfo.category;
      } else {
        // Default based on role
        const roleCategoryMap: { [key: string]: string } = {
          'system-admin': 'VTS Administrator',
          'gps-vendor': 'GPS Vendor',
          'occ': 'OCC'
        };
        this.userCategory = roleCategoryMap[role] || '';
      }
    } catch (e) {
      console.error('Error updating user info:', e);
    }
  }

  private updateBreadcrumb(url: string): void {
    const routeMap: { [key: string]: string } = {
      '/role-selection': this.translate('roleSelection.title'),
      '/vendor-registration': this.translate('vendor.title'),
      '/vendor-otp-verification': 'OTP Verification',
      '/dashboard': this.translate('dashboard.title'),
      '/tracking': this.translate('tracking.title'),
      '/device': this.translate('device.title'),
      '/device/fitment': this.translate('device.fitAndActivate'),
      '/geofence': this.translate('geofence.title'),
      '/vendor': this.translate('vendor.title'),
      '/notifications': this.translate('notifications.title'),
      '/configuration': this.translate('configuration.title')
    };
    this.breadcrumbText = routeMap[url] || this.translate('dashboard.title');
  }

  toggleSidebar(): void {
    // This will be handled by the sidebar component
    const event = new CustomEvent('toggleSidebar');
    window.dispatchEvent(event);
  }

  goToRoleSelection(): void {
    this.router.navigate(['/role-selection']);
  }
}

